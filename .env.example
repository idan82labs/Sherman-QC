# Sherman Scan QC System - Environment Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8080

# ============================================================================
# AI Provider Configuration (Choose one or more)
# ============================================================================

# Anthropic Claude (Recommended for precision inspection)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini (Best for 3D spatial reasoning)
# Get your API key from: https://makersuite.google.com/
GOOGLE_API_KEY=

# OpenAI GPT (Best for abstract reasoning)
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=

# Default AI provider: claude, gemini, or openai
AI_PROVIDER=claude

# AI Model Override (optional - uses provider defaults if not set)
# CLAUDE_MODEL=claude-opus-4-5-20251101
# GEMINI_MODEL=gemini-3-pro
# OPENAI_MODEL=gpt-5.2

# ============================================================================
# Database Configuration
# ============================================================================

# SQLite (default for development)
# DATABASE_URL=sqlite:///data/qc_jobs.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/sherman_qc

# ============================================================================
# Storage Configuration
# ============================================================================

# Upload directory for incoming files
UPLOAD_DIR=./uploads

# Output directory for reports and heatmaps
OUTPUT_DIR=./output

# Data directory for database and logs
DATA_DIR=./data

# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=100

# ============================================================================
# Security Configuration
# ============================================================================

# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-this-to-a-secure-random-string

# JWT token expiration in hours
JWT_EXPIRATION_HOURS=24

# Allowed origins for CORS (comma-separated, * for all)
CORS_ORIGINS=*

# ============================================================================
# QC Analysis Defaults
# ============================================================================

# Default tolerance in mm
DEFAULT_TOLERANCE_MM=0.1

# Default material
DEFAULT_MATERIAL=Al-5053-H32

# Regional analysis minimum points
MIN_REGION_POINTS=100

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional - logs to stdout if not set)
# LOG_FILE=./logs/app.log

# ============================================================================
# Production Settings
# ============================================================================

# Enable production mode (disables debug features)
PRODUCTION=false

# Workers for uvicorn (production)
WORKERS=4

# Request timeout in seconds
REQUEST_TIMEOUT=300

# ============================================================================
# Optional Integrations (Future)
# ============================================================================

# ERP Integration (Phase 3 - not yet implemented)
# ERP_API_URL=
# ERP_API_KEY=

# Webhook notifications (Phase 2)
# WEBHOOK_URL=
# WEBHOOK_SECRET=
